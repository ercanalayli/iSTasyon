# AperiON / ErpaltH iSTasyon
# Gerçek anahtarları ve şifreleri GitHub'a koyma.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_FOR_LOCAL_MIGRATION_ONLY

# BizimHesap bot entegrasyonu için yerel kullanım
BIZIMHESAP_EMAIL=your-email@example.com
BIZIMHESAP_PASSWORD=
BIZIMHESAP_PROFILE_DIR=C:\Users\HP\Desktop\ErpaltH\.bizimhesap-profile
BIZIMHESAP_HEADLESS=true
BIZIMHESAP_EXPORT_DIR=./bizimhesap_exports
APERION_FINANCE_IMPORT_DIR=./finance_imports

# Moka / banka dosyaları için yerel kullanım
BANK_EXPORT_DIR=./bank_exports
MOKA_EXPORT_DIR=./moka_exports

# Telegram Finans Asistanı / Kritik Risk Alarmı
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
COMPANY=ALAYLI
RISK_ALERT_LEVEL=high

# v52 tekrar alarm engeli
# Aynı risk bu süre dolmadan tekrar Telegram'a gönderilmez.
# 360 dakika = 6 saat
RISK_ALERT_COOLDOWN_MINUTES=360
