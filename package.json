{
  "name": "istasyon-bot-service",
  "version": "1.0.0",
  "description": "AperiON iSTasyon Unified Bot Service",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "bot:bizimhesap": "node services/bizimhesap_bot.js",
    "bot:banka": "node services/banka_parser.js",
    "finance-pipeline-demo": "node bizimhesap_finance_pipeline.cjs test_data/bizimhesap_finance_sample.csv alayli",
    "moka-pipeline-demo": "node moka_bank_pipeline.cjs test_data/moka_bank_sample.csv alayli",
    "finance-smoke": "node finance_smoke_test.cjs",
    "finance-verify-manifest": "node scripts/verify_finance_manifest.cjs",
    "finance-test-supabase": "node finance_supabase_connection_test.cjs",
    "finance-inject-index": "node scripts/inject_finance_into_index.cjs",
    "command-center-inject-index": "node scripts/inject_command_center_into_index.cjs",
    "command-center-verify-index": "node scripts/verify_command_center_index_link.cjs",
    "finance-verify-index": "node scripts/verify_finance_index_link.cjs",
    "patch:sales-today-finance-calendar": "node tools/apply_sales_today_finance_calendar_patch_v46.js",
    "verify:sales-today-finance-calendar": "node tools/verify_sales_today_finance_calendar_v46.js",
    "apply:sales-today-finance-calendar": "npm run patch:sales-today-finance-calendar && npm run verify:sales-today-finance-calendar",
    "telegram:hatirlat": "node telegram_hatirlatma_bot.js --once",
    "telegram:hatirlat:watch": "node telegram_hatirlatma_bot.js --watch",
    "telegram:hatirlat:due": "node telegram_hatirlatma_bot.js --remind-only",
    "sync:bizimhesap": "node aperion_veri_senkron.js --firma alayli",
    "sync:bizimhesap:plan": "node aperion_veri_senkron.js --firma alayli --plan",
    "sync:bizimhesap:dry": "node aperion_veri_senkron.js --firma alayli --dry-run",
    "test": "node finance_smoke_test.cjs && node scripts/verify_finance_manifest.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "puppeteer": "^22.0.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  }
}