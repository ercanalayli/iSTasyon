# AperiON Mail Ekstre Otomasyonu
# Bu dosyayı .env olarak kopyala. Gerçek değerleri GitHub'a koyma.

COMPANY_ID=alayli
GMAIL_MAILBOX=alaylimedikal@gmail.com
LOOKBACK_DAYS=7
DRY_RUN=1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost
GOOGLE_REFRESH_TOKEN=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# BizimHesap doğrudan API varsayılmıyor.
# Onaylanan kayıtlar önce bizimhesap_queue tablosuna düşer.
BIZIMHESAP_MODE=queue
